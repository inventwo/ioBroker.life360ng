{
    "i18n": true,
    "type": "tabs",
    "items": {
        "_general": {
            "type": "panel",
            "label": "tab_general",
            "icon": "data:image/svg+xml;base64,",
            "items": {
                "tokenHint": {
                    "type": "staticText",
                    "text": "token_hint",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "style": {
                        "marginBottom": "5px",
                        "fontSize": "0.875rem",
                        "whiteSpace": "pre-wrap"
                    }
                },
                "txtHelp": {
                    "type": "staticText",
                    "label": "help_txt",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "style": {
                        "fontSize": "1rem",
                        "color": "rgb(77, 171, 245)"
                    }
                },
                "life360_token": {
                    "type": "text",
                    "label": "life360_token",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6
                },
                "life360_username": {
                    "type": "text",
                    "label": "life360_username",
                    "help": "life360_username_help",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 6,
                    "xl": 6
                },
                "life360_polling_interval": {
                    "type": "number",
                    "label": "life360_polling_interval",
                    "help": "life360_polling_interval_help",
                    "min": 15,
                    "max": 1440,
                    "step": 1,
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 6,
                    "lg": 6,
                    "xl": 6,
                    "style": {
                        "marginTop": "8px"
                    }
                }
            }
        },
        "_myplaces": {
            "type": "panel",
            "label": "tab_myplaces",
            "icon": "data:image/svg+xml;base64,",
            "items": {
                "txtPlaces": {
                    "type": "staticText",
                    "label": "places_txt",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "style": {
                        "fontSize": "0.875rem"
                    }
                },
                "places": {
                    "type": "table",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "items": [
                        {
                            "title": "place_name",
                            "attr": "name",
                            "type": "text",
                            "width": "25%"
                        },
                        {
                            "title": "place_latitude",
                            "attr": "latitude",
                            "type": "text",
                            "width": "20%"
                        },
                        {
                            "title": "place_longitude",
                            "attr": "longitude",
                            "type": "text",
                            "width": "20%"
                        },
                        {
                            "title": "place_radius",
                            "attr": "radius",
                            "type": "number",
                            "width": "15%"
                        },
                        {
                            "title": "place_circle",
                            "attr": "circle",
                            "type": "text",
                            "width": "20%"
                        }
                    ]
                }
            }
        },
        "_integration": {
            "type": "panel",
            "label": "tab_integration",
            "icon": "data:image/svg+xml;base64,",
            "items": {
                "_life360Data": {
                    "type": "panel",
                    "label": "section_life360_data",
                    "xs": 12,
                    "items": {
                        "process_life360_circles": {
                            "type": "checkbox",
                            "label": "process_life360_circles",
                            "xs": 12,
                            "sm": 12,
                            "md": 4,
                            "lg": 4,
                            "xl": 4
                        },
                        "process_life360_places": {
                            "type": "checkbox",
                            "label": "process_life360_places",
                            "xs": 12,
                            "sm": 12,
                            "md": 4,
                            "lg": 4,
                            "xl": 4
                        },
                        "process_life360_people": {
                            "type": "checkbox",
                            "label": "process_life360_people",
                            "xs": 12,
                            "sm": 12,
                            "md": 4,
                            "lg": 4,
                            "xl": 4
                        }
                    }
                },
                "_placesAdapter": {
                    "type": "panel",
                    "label": "section_places_adapter",
                    "xs": 12,
                    "items": {
                        "sendto_places_adapter_instance": {
                            "type": "number",
                            "label": "sendto_places_adapter_instance",
                            "help": "sendto_places_adapter_instance_help",
                            "min": -1,
                            "xs": 12,
                            "sm": 6,
                            "md": 6,
                            "lg": 6,
                            "xl": 6
                        },
                        "sendto_places_adapter_regexp": {
                            "type": "text",
                            "label": "sendto_places_adapter_regexp",
                            "help": "sendto_places_adapter_regexp_help",
                            "xs": 12,
                            "sm": 12,
                            "md": 6,
                            "lg": 6,
                            "xl": 6
                        }
                    }
                },
                "_locationTracking": {
                    "type": "panel",
                    "label": "section_location_tracking",
                    "xs": 12,
                    "items": {
                        "track_location_people": {
                            "type": "checkbox",
                            "label": "track_location_people",
                            "xs": 12,
                            "sm": 6,
                            "md": 6,
                            "lg": 6,
                            "xl": 6
                        },
                        "location_object_type": {
                            "type": "select",
                            "label": "location_object_type",
                            "options": [
                                {
                                    "label": "LonLat tuple",
                                    "value": "LonLatTuple"
                                },
                                {
                                    "label": "LatLon object",
                                    "value": "LatLon"
                                },
                                {
                                    "label": "LatLng object",
                                    "value": "LatLng"
                                },
                                {
                                    "label": "LatitudeLongitude object",
                                    "value": "LatitudeLongitude"
                                },
                                {
                                    "label": "Latitude,Longitude (comma)",
                                    "value": "CUSTOM_LatCommaLon"
                                },
                                {
                                    "label": "Latitude;Longitude (semicolon)",
                                    "value": "CUSTOM_LatSemicolonLon"
                                }
                            ],
                            "xs": 12,
                            "sm": 6,
                            "md": 6,
                            "lg": 6,
                            "xl": 6
                        },
                        "location_unknown_name": {
                            "type": "text",
                            "label": "location_unknown_name",
                            "help": "location_unknown_name_help",
                            "newLine": true,
                            "xs": 12,
                            "sm": 6,
                            "md": 6,
                            "lg": 6,
                            "xl": 6
                        }
                    }
                }
            }
        },
        "_advanced": {
            "type": "panel",
            "label": "tab_advanced",
            "icon": "data:image/svg+xml;base64,",
            "items": {
                "debugging_verbose": {
                    "type": "checkbox",
                    "label": "debugging_verbose",
                    "newLine": true,
                    "xs": 12,
                    "sm": 6,
                    "md": 6,
                    "lg": 6,
                    "xl": 6
                }
            }
        },
        "_help": {
            "type": "panel",
            "label": "helps",
            "icon": "data:image/svg+xml;base64,",
            "items": {
                "intro": {
                    "type": "staticText",
                    "text": "intro_txt",
                    "newLine": true,
                    "sm": 12,
                    "xs": 12,
                    "md": 10,
                    "lg": 10,
                    "xl": 10,
                    "style": {
                        "marginBottom": "10px",
                        "fontSize": "24px"
                    }
                },
                "txtOne": {
                    "type": "staticText",
                    "text": "token_hint",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "style": {
                        "marginBottom": "16px",
                        "fontSize": "0.875rem",
                        "whiteSpace": "pre-wrap"
                    }
                },
                "txtScreen": {
                    "type": "staticText",
                    "text": "screenshot_txt",
                    "newLine": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "style": {
                        "fontSize": "0.875rem"
                    }
                },
                "token_screen": {
                    "type": "staticImage",
                    "src": "img/token_anonym.png",
                    "newLine": true,
                    "sm": 9,
                    "xs": 9,
                    "md": 9,
                    "lg": 9,
                    "xl": 9,
                    "style": {
                        "marginTop": "2px"
                    }
                },
                "logo": {
                    "type": "staticImage",
                    "src": "img/inventwo.svg",
                    "newLine": true,
                    "sm": 0.5,
                    "xs": 0.5,
                    "md": 0.5,
                    "lg": 0.5,
                    "xl": 0.5,
                    "style": {
                        "marginTop": "25px"
                    }
                },
                "outro": {
                    "type": "staticText",
                    "text": "Team inventwo •  <a href=\"https://github.com/inventwo\">https://github.com/inventwo</a> • by skvarel",
                    "newLine": true,
                    "sm": 12,
                    "xs": 12,
                    "md": 3,
                    "lg": 3,
                    "xl": 3,
                    "style": {
                        "borderTop": "0px solid",
                        "borderColor": "",
                        "marginTop": "0px",
                        "paddingTop": "5px",
                        "fontSize": "14px",
                        "textAlign": "left"
                    }
                },
                "payPal": {
                    "type": "staticLink",
                    "href": "https://www.paypal.com/donate/?hosted_button_id=7W6M3TFZ4W9LW",
                    "target": "_blank",
                    "label": "paypal_donate",
                    "variant": "outlined",
                    "button": true,
                    "icon": "https://www.paypalobjects.com/marketing/web/logos/paypal-mark-color_new.svg",
                    "newLine": true,
                    "sm": 12,
                    "xs": 12,
                    "md": 3,
                    "lg": 3,
                    "xl": 3,
                    "style": {
                        "marginTop": "0px"
                    }
                }
            }
        }
    }
}
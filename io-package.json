    "licenseInformation": {
      "type": "free",
      "license": "MIT",
      "link": "https://raw.githubusercontent.com/inventwo/ioBroker.life360ng/main/LICENSE"
    },
    "tier": 3,
    "platform": "Javascript/Node.js",
    "icon": "Life360_s.svg",
    "enabled": false,
    "extIcon": "https://raw.githubusercontent.com/inventwo/ioBroker.life360ng/main/admin/Life360_s.svg",
    "readme": "https://github.com/inventwo/ioBroker.life360ng/blob/main/README.md",
    "loglevel": "info",
    "mode": "daemon",
    "type": "geoposition",
    "compact": true,
    "adminUI": {
      "config": "json"
    },
    "stopTimeout": 3000,
    "dependencies": [
      {
        "js-controller": ">=6.0.11"
      }
    ],
    "globalDependencies": [
      {
        "admin": ">=7.6.20"
      }
    ],
    "connectionType": "cloud",
    "dataSource": "poll"
  },
  "protectedNative": [
    "life360_token"
  ],
  "encryptedNative": [
    "life360_token"
  ],
  "native": {
    "life360_username": "",
    "life360_token": "",
    "life360_polling_interval": "60",
    "places": [],
    "sendto_places_adapter_instance": -1,
    "sendto_places_adapter_regexp": "",
    "location_unknown_name": "",
    "track_location_people": true,
    "location_object_type": "LatLng",
    "process_life360_circles": true,
    "process_life360_places": true,
    "process_life360_people": true,
    "debugging_verbose": false
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": "Information"
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": "connected",
        "desc": "Connected to Life360 cloud services?",
        "type": "boolean",
        "def": false,
        "read": true,
        "role": "value.info",
        "write": false
      },
      "native": {}
    },
    {
      "_id": "circles",
      "type": "device",
      "common": {
        "name": "Circles",
        "desc": "Life360 circles."
      },
      "native": {}
    },
    {
      "_id": "places",
      "type": "device",
      "common": {
        "name": "Places",
        "desc": "Life360 places."
      },
      "native": {}
    },
    {
      "_id": "people",
      "type": "device",
      "common": {
        "name": "People",
        "desc": "Life360 people."
      },
      "native": {}
    },
    {
      "_id": "myplaces",
      "type": "device",
      "common": {
        "name": "My Places",
        "desc": "Custom places apart from Life360."
      },
      "native": {}
    }
  ]
